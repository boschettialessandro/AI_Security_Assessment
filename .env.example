# Copia questo file in .env e modifica i valori

# Porta del server (Railway/Render lo impostano automaticamente)
PORT=3000

# Secret per le sessioni — CAMBIA con una stringa random lunga (almeno 32 caratteri)
SESSION_SECRET=cambia-questo-valore-con-una-stringa-random-sicura

# Directory dati (percorso assoluto o relativo)
# Su Railway/Render con volume: /data
# In locale: lascia vuoto (usa ./data di default)
DATA_DIR=./data
